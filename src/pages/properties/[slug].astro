---
import MainLayout from "../../layouts/MainLayout.astro";
import properties from "../../data/properties.json";
import agent from "../../data/agent.json";

export function getStaticPaths() {
  return properties.map((property) => ({
    params: { slug: property.slug },
    props: { property },
  }));
}

const { property } = Astro.props;

if (!property) {
  Astro.response.status = 404;
}

const site = import.meta.env.SITE;
const base = import.meta.env.BASE_URL;
const abs = (p: string) =>
  new URL(base + p.replace(/^\/+/, ""), site).toString();
const priceNumber = Number(String(property.price).replace(/[^\d]/g, ""));
const isForSale = property.status === "À venda";

const whatsappMessage = property.location
  ? `Olá, tenho interesse no imóvel "${property.title}" em ${property.location}.`
  : `Olá, tenho interesse no imóvel "${property.title}".`;
const whatsappHref = `https://wa.me/${agent.whatsapp}?text=${encodeURIComponent(whatsappMessage)}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateListing",
  name: property.title,
  description: property.description || undefined,
  url: new URL(Astro.url.pathname, site).toString(),
  image: (property.images || []).map(abs),
  address: { "@type": "PostalAddress", addressLocality: property.location },
  ...(priceNumber
    ? {
        offers: {
          "@type": "Offer",
          price: priceNumber,
          priceCurrency: "BRL",
          availability: isForSale
            ? "https://schema.org/InStock"
            : "https://schema.org/LimitedAvailability",
        },
      }
    : {}),
};
---

<MainLayout
  title={`${property.title} — ${property.location}`}
  description={property.description || ""}
  ogImage={property.mainImage || property.images?.[0]}
  ogType="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <a
      href={import.meta.env.BASE_URL}
      class="inline-block text-accent font-semibold hover:underline mb-6"
    >
      ← Início
    </a>

    <div class="flex items-center gap-3 mb-4">
      <span
        class="inline-block bg-accent text-white text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full"
      >
        {property.status}
      </span>
    </div>

    <h1 class="text-4xl md:text-5xl font-bold text-primary mb-2">
      {property.title}
    </h1>
    <p class="text-xl text-gray-700 font-medium mb-6">{property.price}</p>
    <p class="text-gray-500 mb-8 flex items-center gap-1">
      <svg
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
        ></path>
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      {property.location}
    </p>

    {
      agent.whatsapp && (
        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-green-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-green-700 transition-colors mb-8"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          Interessado? Fale no WhatsApp
        </a>
      )
    }

    {
      property.description && (
        <p class="text-gray-700 text-lg leading-relaxed mb-8">
          {property.description}
        </p>
      )
    }

    {
      property.features && property.features.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-12">
          {property.features.map((feature) => (
            <span class="bg-gray-100 text-gray-700 text-sm font-medium px-3 py-1 rounded-full">
              {feature}
            </span>
          ))}
        </div>
      )
    }

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
      {
        property.images.map((image) => (
          <img
            src={`${import.meta.env.BASE_URL}${image.replace(/^\/+/, "")}`}
            alt={`${property.title} — ${property.location}`}
            class="w-full max-h-[80vh] object-contain rounded-lg shadow-sm"
            loading="lazy"
          />
        ))
      }
    </div>
  </section>
</MainLayout>
