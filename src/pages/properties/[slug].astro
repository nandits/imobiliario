---
import MainLayout from '../../layouts/MainLayout.astro';
import properties from '../../data/properties.json';
import ContactBlock from '../../components/ContactBlock.astro';

export function getStaticPaths() {
  return properties.map((property) => ({
    params: { slug: property.slug },
    props: { property },
  }));
}

const { property } = Astro.props;
---

<MainLayout
  title={property ? `${property.title} — ${property.location}` : 'Imóvel não encontrado'}
  description={property?.description || ''}
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {!property ? (
      <div class="text-center py-20">
        <h1 class="text-3xl font-bold text-primary mb-4">Imóvel não encontrado</h1>
        <p class="text-gray-600 mb-8">O imóvel que procura não existe ou foi removido.</p>
        <a href="/properties" className="text-accent font-semibold hover:underline">
          ← Voltar às Propriedades
        </a>
      </div>
    ) : (
      <>
        <a href="/properties" class="inline-block text-accent font-semibold hover:underline mb-6">
          ← Voltar às Propriedades
        </a>

        <div class="flex items-center gap-3 mb-4">
          <span class="inline-block bg-accent text-white text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">
            {property.status}
          </span>
        </div>

        <h1 class="text-4xl md:text-5xl font-bold text-primary mb-2">{property.title}</h1>
        <p class="text-xl text-gray-700 font-medium mb-6">{property.price}</p>
        <p class="text-gray-500 mb-8 flex items-center gap-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          {property.location}
        </p>

        {property.description && (
          <p class="text-gray-700 text-lg leading-relaxed mb-8">{property.description}</p>
        )}

        {property.features && property.features.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-12">
            {property.features.map((feature) => (
              <span class="bg-gray-100 text-gray-700 text-sm font-medium px-3 py-1 rounded-full">
                {feature}
              </span>
            ))}
          </div>
        )}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
          {property.images.map((image) => (
            <img
              key={image}
              src={image}
              alt={`${property.title} — ${property.location}`}
              class="w-full aspect-[4/3] object-cover rounded-lg shadow-sm"
              loading="lazy"
            />
          ))}
        </div>

        <ContactBlock />
      </>
    )}
  </section>
</MainLayout>
