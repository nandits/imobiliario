---
import agent from "../data/agent.json";

const links = [
  { href: import.meta.env.BASE_URL, label: "Início" },
  { href: `${import.meta.env.BASE_URL}agent`, label: "Sobre Mim" },
];

const displayName = agent.shortName || agent.name;
const brand = agent.creci
  ? `${displayName} | CRECI:${agent.creci}`
  : displayName;
---

<header
  class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="text-xl font-bold text-primary">
        {brand}
      </a>

      <nav class="hidden md:flex items-center gap-6">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium text-gray-700 hover:text-accent transition-colors"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <button
        id="mobile-menu-button"
        class="md:hidden p-2 rounded-md text-gray-700 hover:text-accent"
        aria-label="Abrir menu"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <nav class="flex flex-col gap-2">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium text-gray-700 hover:text-accent py-2"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<script>
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  button?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
