---
import agent from "../data/agent.json";
---

<footer class="bg-primary text-white mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-lg font-semibold mb-3">{agent.name}</h3>
        <p class="text-gray-300 text-sm">{agent.bio}</p>
      </div>

      <div>
        <h4
          class="text-sm font-semibold uppercase tracking-wider mb-3 text-gray-300"
        >
          Contacto
        </h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href={`tel:${agent.phone}`}
              class="text-gray-200 hover:text-white transition-colors"
            >
              {agent.phone}
            </a>
          </li>
          <li>
            <a
              href={`https://wa.me/${agent.whatsapp}?text=Olá,%20estou%20interessado%20num%20imóvel.`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-200 hover:text-white transition-colors"
            >
              WhatsApp
            </a>
          </li>
          <li>
            <a
              href={`mailto:${agent.email}`}
              class="text-gray-200 hover:text-white transition-colors"
            >
              {agent.email}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4
          class="text-sm font-semibold uppercase tracking-wider mb-3 text-gray-300"
        >
          Website
        </h4>
        <p class="text-sm text-gray-200">
          © {new Date().getFullYear()} Armando Costa. Todos os direitos reservados.
        </p>
      </div>
    </div>
  </div>
</footer>
