---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description = "", ogImage, ogType = "website" } = Astro.props;

const site = import.meta.env.SITE;
const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, site).toString();
const ogUrl = canonical;
const ogImageAbs = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : new URL(base + ogImage.replace(/^\/+/, ""), site).toString()
  : undefined;
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
    <meta name="twitter:card" content={ogImageAbs ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImageAbs && <meta name="twitter:image" content={ogImageAbs} />}
    <link rel="canonical" href={canonical} />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
